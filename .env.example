# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your api key
# ── Optional (improves results) ───────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile       # or mixtral-8x7b-32768

KAGGLE_USERNAME=username
KAGGLE_KEY=kaggle key 
HF_TOKEN= hf kaey           # Only needed for private datasets

SERPAPI_KEY=your_serpapi_key     # Falls back to DuckDuckGo if not set

GITHUB_TOKEN=ghp_your_token      # Raises GitHub API rate limit to 5000/hr

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_IMAGES=200
MAX_ITERATIONS=100
